# Mitosis 环境变量示例
# 复制为 .env.local 后填入实际值：cp .env.example .env.local
# .env.local 已加入 .gitignore，不会被提交

# ── GitHub OAuth ──────────────────────────────────────
VITE_GITHUB_CLIENT_ID=your-github-oauth-client-id
VITE_GITHUB_REPO_OWNER=zenHeart
VITE_GITHUB_REPO_NAME=mitosis

# ── GitHub Token（可选，本地开发自动登录用） ──────────
# 在 GitHub Settings → Developer settings → Personal access tokens 生成
# 需要 repo 权限
VITE_GITHUB_TOKEN=ghp_xxxx

# ── StepFun API Token（可选，AI 对话功能需要） ─────────
VITE_STEP_TOKEN=your-stepfun-api-key

# ── Mock 模式（本地开发无需 GitHub 仓库） ─────────────
# true: 所有 GitHub API 调用路由到 localStorage
# false: 正常调用 GitHub API（开发模式走 Vite proxy，生产模式直连）
VITE_USE_MOCK_GITHUB=false

# ── 本地代理（Vite dev server 自动配置） ──────────────
# /api/github/* → 自动代理到 api.github.com
# 无需手动配置，在 vite.config.ts 中定义
