.claude/.goal-state.json
.claude/.goal-verdict
.claude/verification-report.txt
.claude/settings.local.json
settings.local.json
.env.local

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs (root project only)
dist/
dist-ssr/
*.local
# Build output assets (root dist only)
dist/assets/
# Build outputs for generated apps (not committed — CI rebuilds)
apps/*/v*/dist/
# Allow app-specific source and entry points
!apps/*/v*/index.html
!apps/*/v*/src/
!apps/*/v*/package.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
apps/*/v*/test-results/
apps/*/v*/playwright-report/

# Misc
.cache/

# Generated TypeScript/Vite artifacts
*.d.ts
*.tsbuildinfo
# Allow app vite-env.d.ts
!apps/*/v*/src/vite-env.d.ts
src/**/*.d.ts
src/**/*.js
!src/**/*.vue.js*.d.ts
*.tsbuildinfo

# Playwright MCP temp files
.playwright-mcp/
*.png
# Keep .gitkeep in apps/ root
apps/.gitkeep
dist/
playwright-report/
test-results/